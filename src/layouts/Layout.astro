---
/* 
 * Version: 0.3 
 * Date: 2026-07-16 16:45
 */

import '../styles/global.css';
import Header from '../components/layout/Header.astro'; // 1. Import the component


interface Props {
  title: string;
}

const { title } = Astro.props;
---
<style>
  path {
    cursor: pointer;
    transition: fill 0.2s;
  }
  path:hover {
    fill: #f0f0f0; /* Light highlight on hover */
  }
</style>

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Cloud Ursa LTD - Salesforce and API Integration Experts" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-white text-gray-900 font-sans">
    
    <Header /> <!-- 2. Use the component here -->
    
    <main class="max-w-4xl mx-auto px-6 py-12">
      <slot />
    </main>

    <footer class="text-center py-10 mt-10 border-t text-sm text-gray-500">
      &copy; {new Date().getFullYear()} Cloud Ursa LTD. All rights reserved.
    </footer>
  </body>
</html>