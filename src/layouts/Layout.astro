---
/* 
 * Version: 0.6 
 * Date: 2026-07-23 12:10
 */

import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { 
  title, 
  description = "Cloud Ursa — UK-based Salesforce Consulting, API Integration & System Recovery Experts.",
  ogImage = "/og-image.png"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || "https://cloudursa.com");
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    
    <!-- Title & SEO Meta -->
    <title>{title} | Cloud Ursa</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Social Media -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | Cloud Ursa`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, canonicalURL)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={`${title} | Cloud Ursa`} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(ogImage, canonicalURL)} />
  </head>
  <body class="bg-white text-gray-900 font-sans flex flex-col min-h-screen">
    
    <Header />
    
    <main class="flex-grow">
      <slot />
    </main>

    <Footer />
    
  </body>
</html>