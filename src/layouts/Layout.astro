---
/* 
 * Version: 0.2 
 * Date: 2026-07-16 16:05
 */

import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Cloud Ursa LTD - Salesforce and API Integration Experts" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-white text-gray-900 font-sans">
    <header class="border-b p-6">
      <nav class="max-w-4xl mx-auto flex justify-between items-center">
        <a href="/" class="text-2xl font-bold tracking-tight">Cloud Ursa</a>
        <div class="flex space-x-6">
          <a href="/services" class="hover:text-blue-600">Services</a>
          <a href="/ringstrue" class="hover:text-blue-600">RingsTrue</a>
          <a href="/contact" class="hover:text-blue-600 font-semibold text-blue-600">Contact</a>
        </div>
      </nav>
    </header>
    
    <slot />

    <footer class="text-center py-10 mt-10 border-t text-sm text-gray-500">
      &copy; {new Date().getFullYear()} Cloud Ursa LTD. All rights reserved.
    </footer>
  </body>
</html>