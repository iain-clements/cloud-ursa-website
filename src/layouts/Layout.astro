import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro'; // 1. Import the component

interface Props {
  title: string;
}

const { title } = Astro.props;
---
<style>
  path {
    cursor: pointer;
    transition: fill 0.2s;
  }
  path:hover {
    fill: #f0f0f0;
  }
</style>

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Cloud Ursa LTD - Salesforce and API Integration Experts" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />    
<link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <title>{title}</title>

    
  </head>
  <body class="bg-white text-gray-900 font-sans flex flex-col min-h-screen">
    
    <Header />
    
    <main class="flex-grow">
      <slot />
    </main>

    <Footer /> <!-- 2. Use the component here -->
    
  </body>
</html>