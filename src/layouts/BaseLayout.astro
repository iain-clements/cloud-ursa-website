---
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import "../styles/global.css";

interface Props {
    title: string;
    description?: string;
}

const {
    title,
    description = "Cloud Ursa"
} = Astro.props;
---

<!doctype html>

<html lang="en">

<head>

<meta charset="UTF-8"/>

<meta name="viewport" content="width=device-width"/>

<title>{title}</title>

<meta
name="description"
content={description}/>

</head>

<body class="bg-white text-slate-900">

<Header />

<main>

<slot />

</main>

<Footer />

</body>

</html>