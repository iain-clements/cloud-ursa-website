---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-50 border-t mt-auto py-8">
  <div class="container mx-auto px-6 flex flex-col md:flex-row justify-between items-center text-sm text-gray-600">
    
    <!-- Copyright -->
    <p class="mb-4 md:mb-0">
      &copy; {currentYear} Cloud Ursa LTD. All rights reserved.
    </p>

    <!-- Navigation -->
    <nav>
      <ul class="flex space-x-6">
        <li><a href="/" class="hover:text-blue-600 transition-colors">Home</a></li>
        <li><a href="/terms" class="hover:text-blue-600 transition-colors">Terms & Conditions</a></li>
        <li><a href="/contact" class="hover:text-blue-600 transition-colors">Contact</a></li>
      </ul>
    </nav>
  </div>
</footer>