---
/* 
 * Version: 0.3 
 * Date: 2026-07-23 12:10
 */
import Container from "../ui/Container.astro";
---
<footer class="bg-gray-900 text-gray-300 py-12 border-t border-gray-800">
  <Container>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
      <!-- Company Info -->
      <div class="md:col-span-1">
        <a href="/" class="block mb-4">
          <img src="/logo.svg" alt="Cloud Ursa Logo" class="h-10 w-auto filter brightness-0 invert" />
        </a>
        <p class="text-sm text-gray-400 mb-4">
          UK-based Salesforce & API Integration Partner specializing in custom middleware, platform recovery, and data quality.
        </p>
        <p class="text-xs text-gray-500">Cloud Ursa LTD | Registered in England & Wales</p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Services</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/services" class="hover:text-white transition">Overview</a></li>
          <li><a href="/services/managed-services" class="hover:text-white transition">Managed Services</a></li>
          <li><a href="/services/data-quality" class="hover:text-white transition">Data Quality Services</a></li>
        </ul>
      </div>

      <!-- Products & Case Studies -->
      <div>
        <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Solutions & Apps</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/ringstrue" class="hover:text-white transition">RingsTrue App</a></li>
          <li><a href="/map" class="hover:text-white transition">Country Code Map</a></li>
          <li><a href="/case-studies" class="hover:text-white transition">Case Studies</a></li>
          <li><a href="/blog" class="hover:text-white transition">Insights & Blog</a></li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Get in Touch</h4>
        <p class="text-sm text-gray-400 mb-1">Phone: <a href="tel:+447734389366" class="hover:text-white">+44 7734 389366</a></p>
        <p class="text-sm text-gray-400 mb-4">Email: <a href="mailto:sales@cloudursa.com" class="hover:text-white">sales@cloudursa.com</a></p>
        <a href="/contact" class="inline-block bg-blue-600 text-white text-xs font-bold px-4 py-2 rounded hover:bg-blue-700 transition">Book Consultation</a>
      </div>
    </div>

    <div class="border-t border-gray-800 pt-8 flex flex-col md:flex-row justify-between items-center text-xs text-gray-500">
      <p>© {new Date().getFullYear()} Cloud Ursa LTD. All rights reserved.</p>
      <div class="flex space-x-6 mt-4 md:mt-0">
        <a href="/terms" class="hover:text-gray-400">Terms & Conditions</a>
        <a href="/privacy" class="hover:text-gray-400">Privacy Policy</a>
      </div>
    </div>
  </Container>
</footer>