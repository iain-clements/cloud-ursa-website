import Container from "../ui/Container.astro";
---
<header class="py-6 border-b px-6">
  <Container>
    <div class="flex justify-between items-center">
      <a href="/" class="text-2xl font-bold tracking-tight">
        Cloud <span style="color:#2563eb">Ursa</span>
      </a>
      
      <nav class="flex items-center space-x-6">
        <div class="relative group">
          <button class="font-medium hover:text-blue-600 flex items-center">
            Services ▾
          </button>
          <div class="absolute right-0 top-full pt-2 hidden group-hover:block w-48 bg-white border shadow-lg rounded-lg z-50">
            <a href="/services" class="block px-4 py-2 hover:bg-gray-50">Overview</a>
            <a href="/services/managed-services" class="block px-4 py-2 hover:bg-gray-50">Managed Services</a>
            <a href="/services/data-quality" class="block px-4 py-2 hover:bg-gray-50">Data Quality</a>
          </div>
        </div>
        <div class="relative group">
          <button class="font-medium hover:text-blue-600 flex items-center">
            Apps ▾
          </button>
          <div class="absolute right-0 top-full pt-2 hidden group-hover:block w-48 bg-white border shadow-lg rounded-lg z-50">
        <a href="/ringstrue" class="block px-4 py-2 hover:bg-gray-50">RingsTrue</a>
