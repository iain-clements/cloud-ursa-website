---
import { countryCodes } from '../data/countryCodes.js';
---

<div id="map-wrapper" class="relative w-full max-w-4xl mx-auto">
  <svg viewBox="0 0 1000 500" class="w-full h-auto">
    <path id="GB" class="country hover:fill-blue-500 fill-gray-200 transition" d="..." />
    <path id="US" class="country hover:fill-blue-500 fill-gray-200 transition" d="..." />
    </svg>
  
  <div id="tooltip" class="absolute hidden p-2 bg-black text-white text-xs rounded shadow-lg pointer-events-none"></div>
</div>

<script is:inline define:vars={{ countryCodes }}>
  const paths = document.querySelectorAll('.country');
  const tooltip = document.getElementById('tooltip');

  paths.forEach(path => {
    path.addEventListener('mouseover', (e) => {
      // Find the match in your data file
      const match = countryCodes.find(c => c.iso === e.target.id); // Ensure your data has ISO codes!
      if(match) {
        tooltip.style.display = 'block';
        tooltip.style.left = e.pageX + 'px';
        tooltip.style.top = e.pageY + 'px';
        tooltip.textContent = `${match.name}: ${match.code}`;
      }
    });

    path.addEventListener('mouseout', () => {
      tooltip.style.display = 'none';
    });
  });
</script>