---
/* 
 * Version: 0.6
 * Date: 2026-07-17 12:00
 */
import { countryCodes } from '../data/countrycodes.js';
const random = countryCodes[Math.floor(Math.random() * countryCodes.length)];
---

<section class="my-12">
  <div class="bg-white shadow-md rounded-xl border-2 border-blue-600 p-6 md:p-8">
    <div class="flex flex-col gap-3">
      <span class="text-xs font-bold uppercase tracking-widest text-blue-600">
        Global Insight
      </span>
      <p class="text-xl font-medium text-gray-950 leading-snug">
        Did you know? The international dialing code for <span class="text-blue-700 font-semibold">{random.name}</span> is <span class="font-mono bg-blue-50 px-1.5 py-0.5 rounded text-blue-800">{random.code}</span>.
      </p>
      <a href="/quiz" class="inline-flex items-center text-base font-semibold text-blue-600 hover:text-blue-800 transition-colors">
        Test your knowledge in our Country Code Quiz 
        <svg class="ml-1.5 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
      </a>
    </div>
  </div>
</section>