---
import Container from "../ui/Container.astro";
import Button from "../ui/Button.astro";
---

<section class="relative overflow-hidden py-24 lg:py-36">

    <Container>

        <div class="grid gap-16 lg:grid-cols-2 items-center">

            <div>

                <div class="inline-flex rounded-full bg-blue-50 px-4 py-2 text-sm text-blue-700">

                    Salesforce • Automation • Integrations

                </div>

                <h1 class="mt-8 text-5xl font-bold tracking-tight lg:text-7xl">

                    Build systems that
                    <span class="text-blue-600">
                        work together.
                    </span>

                </h1>

                <p class="mt-8 max-w-xl text-xl text-slate-600">

                    Cloud Ursa helps organisations automate processes,
                    integrate business systems and unlock the full
                    potential of Salesforce.

                </p>

                <div class="mt-10 flex flex-wrap gap-4">

                    <Button href="/contact">

                        Book a Discovery Call

                    </Button>

                    <Button
                        href="/services"
                        variant="secondary">

                        Explore Services

                    </Button>

                </div>

            </div>

            <div class="relative">

                <div class="rounded-3xl border border-slate-200 bg-white p-10 shadow-xl">

                    <div class="space-y-5">

                        <div class="rounded-xl border p-4">

                            Salesforce

                        </div>

                        <div class="rounded-xl border p-4">

                            Microsoft 365

                        </div>

                        <div class="rounded-xl border p-4">

                            Website

                        </div>

                        <div class="rounded-xl border p-4">

                            Accounting

                        </div>

                        <div class="rounded-xl border p-4">

                            APIs

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </Container>

</section>