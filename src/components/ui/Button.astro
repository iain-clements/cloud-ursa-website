---
interface Props {
    href?: string;
    variant?: "primary" | "secondary";
}

const {
    href = "#",
    variant = "primary"
} = Astro.props;
---

<a
    href={href}
    class:list={[
        "inline-flex items-center rounded-full px-6 py-3 font-medium transition-all duration-200",
        variant === "primary"
            ? "bg-blue-600 text-white hover:bg-blue-700"
            : "border border-slate-300 hover:bg-slate-100"
    ]}
>
    <slot />
</a>