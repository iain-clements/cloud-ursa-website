---
/* * Version: 0.1 
 * Date: 2026-07-16 18:30
 */
import Layout from '../../layouts/Layout.astro';
import Container from '../../components/ui/Container.astro';

const services = [
  { title: "Data Assessment", desc: "We audit your current Org to identify duplicates, incomplete records, and stale data that is costing you money." },
  { title: "Cleansing & Deduplication", desc: "Automated and manual cleanup strategies to merge duplicate records and standardize field entries." },
  { title: "Governance Strategy", desc: "Establish long-term processes and validation rules to ensure your data stays clean as you scale." },
  { title: "Migration Cleanup", desc: "Pre-migration grooming to ensure you aren't moving 'junk' data into your new environment." }
];
---

<Layout title="Data Quality Services | Cloud Ursa">
  <Container>
    <main class="py-16">
      <div class="max-w-3xl mb-16">
        <h1 class="text-4xl font-bold mb-6">Data Quality Services</h1>
        <p class="text-xl text-gray-600 leading-relaxed">
          Your CRM is only as good as the data inside it. We help you transform messy, 
          unreliable databases into a single, trusted source of truth.
        </p>
      </div>

      <section class="grid md:grid-cols-2 gap-8 mb-20">
        {services.map(s => (
          <div class="p-8 border rounded-lg bg-gray-50">
            <h3 class="text-2xl font-bold mb-3">{s.title}</h3>
            <p class="text-gray-700 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </section>

      <section class="bg-blue-900 text-white p-12 rounded-2xl">
        <h2 class="text-3xl font-bold mb-6">The Cost of Bad Data</h2>
        <p class="text-lg mb-8 opacity-90">
          Inefficient sales teams, inaccurate forecasting, and poor customer experiences are almost always 
          traced back to data quality issues. We don't just clean your data—we fix the processes that 
          made it dirty in the first place.
        </p>
        <a href="/contact" class="inline-block bg-blue-600 hover:bg-blue-500 text-white px-8 py-3 rounded-lg font-bold">
          Request a Data Audit
        </a>
      </section>
    </main>
  </Container>
</Layout>