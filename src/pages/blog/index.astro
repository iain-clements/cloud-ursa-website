---
/* 
 * Version: 0.2
 * Date: 2026-07-17 10:05
 */
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Container from '../../components/ui/Container.astro';
import ClientMarquee from '../../components/ClientMarquee.astro';

// Fetch the posts
const allPosts = await getCollection('blog');
---

<Layout title="Insights">
  <Container>
    <h1 class="text-4xl font-bold mb-8">Insights</h1>

    <ul class="space-y-6">
      {allPosts.map((post) => (
        <li>
          <!-- Link points to the ID, which matches our [id].astro file -->
          <a href={`/blog/${post.id}`} class="text-2xl font-semibold text-blue-600 hover:underline">
            {post.data.title}
          </a>
          <p class="text-gray-600 mt-1">
            {post.data.description || "A technical insight from Cloud Ursa."}
          </p>
        </li>
      ))}
    </ul>

    <section class="py-16 text-center">
      <ClientMarquee />
    </section>
  </Container>
</Layout>