---
/* 
 * Version: 0.1 
 * Date: 2026-07-16 16:55
 */
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Container from '../../components/ui/Container.astro';

// Fetch the posts you already created
const allPosts = await getCollection('blog');
---

<Layout title="Insights">
  <Container>
    <h1 class="text-4xl font-bold mb-8">Insights</h1>
    <ul class="space-y-6">
      {allPosts.map((post) => (
        <li>
          <a href={`/blog/${post.id}`} class="text-2xl font-semibold text-blue-600 hover:underline">
            {post.data.title}
          </a>
          <p class="text-gray-600 mt-1">
            {post.data.description || "A technical insight from Cloud Ursa."}
          </p>
        </li>
      ))}
    </ul>
  </Container>
</Layout>