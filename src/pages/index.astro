---
/* 
 * Version: 0.2 
 * Date: 2026-07-16 17:10
 */

import Layout from '../layouts/Layout.astro';
import Container from '../components/ui/Container.astro';
import ClientMarquee from '../components/ClientMarquee.astro';
import DynamicFeature from '../components/DynamicFeature.astro';
import { caseStudies } from '../data/casestudies.js';

const coreClouds = [
  { name: "Sales Cloud", desc: "Optimize sales pipelines, lead routing, and revenue reporting." },
  { name: "Service Cloud", desc: "Streamline customer support workflows, omni-channel, and case management." },
  { name: "Marketing Cloud / Account Engagement", desc: "Automate targeted cross-channel marketing & B2B lead nurturing." },
  { name: "Custom API & Middleware", desc: "Connect Salesforce seamlessly with internal databases, ERPs, and external services." }
];


---

<Layout title="Cloud Ursa LTD | Salesforce & API Integration Experts">

  
<main class="max-w-4xl mx-auto px-6 py-16">
      <section class="text-center py-12">
      <h1 class="text-5xl font-extrabold text-gray-900 tracking-tight">
        Complex Salesforce Challenges, <span class="text-blue-600">Simplified.</span>
      </h1>
      <p class="mt-6 text-xl text-gray-600 max-w-2xl mx-auto">
        We bridge the gap between your business goals and technical reality. From custom API integrations to platform rescue missions, Cloud Ursa ensures your CRM works for you.
      </p>
      <div class="mt-10 flex gap-4 justify-center">
        <a href="/contact" class="bg-blue-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-blue-700 transition">
          Book a Consultation
        </a>
      </div>
    </section>

        <!-- Core Platforms Grid -->
  <section class="py-16 bg-white">
    <Container>
      <div class="text-center max-w-2xl mx-auto mb-12">
        <h2 class="text-3xl font-bold text-gray-900">Platforms We Support</h2>
        <p class="text-gray-600 mt-2">Deep expertise across the complete Salesforce ecosystem.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {coreClouds.map(cloud => (
          <div class="p-5 border border-gray-100 rounded-lg bg-gray-50">
            <h4 class="font-bold text-gray-900 mb-1">{cloud.name}</h4>
            <p class="text-xs text-gray-600">{cloud.desc}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

      <!-- Hero Section -->
  <section class="py-16 text-center">
    <ClientMarquee />
  </section>



  <!-- Product Spotlight: RingsTrue -->
  <section class="py-16 bg-blue-50 border-y border-blue-100">
    <Container>
      <div class="grid md:grid-cols-2 gap-8 items-center">
        <div>
          <span class="text-blue-600 font-bold text-xs uppercase tracking-wider">Featured App</span>
          <h2 class="text-3xl font-bold text-gray-900 mt-1 mb-4">RingsTrue for Salesforce</h2>
          <p class="text-gray-700 mb-6 leading-relaxed">
            Stop losing leads to incorrect phone numbers. RingsTrue formats, validates, and screens telephone numbers against TPS compliance regulations right inside your Salesforce environment.
          </p>
          <a href="/ringstrue" class="inline-block bg-blue-600 text-white font-bold px-6 py-3 rounded-lg hover:bg-blue-700 transition">
            Explore RingsTrue →
          </a>
        </div>
        <div class="bg-white p-6 rounded-xl shadow-md border border-gray-200">
          <h4 class="font-bold text-gray-900 mb-2">Why Phone Data Quality Matters:</h4>
          <ul class="space-y-2 text-sm text-gray-600">
            <li class="flex items-center gap-2">✓ Automatic E.164 phone number formatting</li>
            <li class="flex items-center gap-2">✓ UK TPS compliance screening</li>
            <li class="flex items-center gap-2">✓ Native Salesforce execution with zero data leaving your org</li>
          </ul>
        </div>
      </div>
    </Container>
  </section>

    <!-- Core Services Grid -->
  <section class="py-16 bg-white border-t border-gray-100">
    <Container>
      <div class="text-center max-w-2xl mx-auto mb-12">
        <h2 class="text-3xl font-bold text-gray-900">How We Help Your Business</h2>
        <p class="text-gray-600 mt-2">Whether implementing from scratch, optimizing, or rescuing a stalled org.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="p-6 rounded-xl border border-gray-100 shadow-sm hover:shadow-md transition bg-white">
          <h3 class="text-xl font-bold text-gray-900 mb-2">Integration & Middleware</h3>
          <p class="text-gray-600 text-sm leading-relaxed">Secure, real-time data pipelines connecting Salesforce to ERPs, custom databases, and external platforms.</p>
        </div>
        <div class="p-6 rounded-xl border border-gray-100 shadow-sm hover:shadow-md transition bg-white">
          <h3 class="text-xl font-bold text-gray-900 mb-2">Org Recovery & Rescue</h3>
          <p class="text-gray-600 text-sm leading-relaxed">System audits and rescue missions for struggling orgs. We stabilize, document, and eliminate technical debt.</p>
        </div>
        <div class="p-6 rounded-xl border border-gray-100 shadow-sm hover:shadow-md transition bg-white">
          <h3 class="text-xl font-bold text-gray-900 mb-2">Data Quality & Tooling</h3>
          <p class="text-gray-600 text-sm leading-relaxed">Proprietary tools like RingsTrue to keep your phone data validated, structured, and TPS compliant.</p>
        </div>
      </div>
    </Container>
  </section>

  
<!-- Trust Anchor -->

<!-- Featured Content -->
  <section class="py-16">
    <Container>
      <!-- We pass the caseStudies data into the component -->
      <DynamicFeature studies={caseStudies} />
    </Container>
  </section>


  

    <!-- Value Proposition -->
    <section class="py-16 grid md:grid-cols-3 gap-8">
      <div class="p-6 border rounded-xl hover:shadow-lg transition">
        <h3 class="text-xl font-bold">Integration</h3>
        <p class="mt-2 text-gray-600">Secure, real-time middleware connecting your Salesforce to any ERP or proprietary database.</p>
      </div>
      <div class="p-6 border rounded-xl hover:shadow-lg transition">
        <h3 class="text-xl font-bold">Recovery</h3>
        <p class="mt-2 text-gray-600">Rescue missions for struggling Orgs. We stabilize, document, and streamline your environment.</p>
      </div>
      <div class="p-6 border rounded-xl hover:shadow-lg transition">
        <h3 class="text-xl font-bold">Tooling</h3>
        <p class="mt-2 text-gray-600">Engineered custom solutions like RingsTrue to keep your data clean and actionable.</p>
      </div>
    </section>



  </main>
</Layout> 