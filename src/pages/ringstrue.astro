import Layout from '../layouts/Layout.astro';
---

<Layout title="RingsTrue | Cloud Ursa LTD">
  <main class="max-w-4xl mx-auto py-16 px-6">
    <h1 class="text-4xl font-extrabold text-gray-900">RingsTrue</h1>
    <p class="text-xl text-blue-600 font-medium mt-2">Precision Data Validation for Salesforce</p>
    
    <div class="mt-8 prose prose-lg text-gray-600">
      <p>
        RingsTrue is our signature suite designed to ensure your data remains clean, validated, and actionable at the point of entry. 
        It eliminates the "garbage in, garbage out" cycle that plagues many growing Salesforce organizations.
      </p>
      
      <h2 class="text-2xl font-bold mt-8 text-gray-900">Key Benefits</h2>
      <ul class="list-disc pl-6 space-y-2">
        <li><strong>Real-time Validation:</strong> Catch errors before they hit your database.</li>
        <li><strong>Configurable Rules:</strong> Adapt to your specific business logic without complex code.</li>
        <li><strong>Reduced Technical Debt:</strong> Keep your Org clean, performant, and reliable.</li>
      </ul>
    </div>

    <div class="mt-12 p-8 bg-blue-50 rounded-xl">
      <h3 class="text-xl font-bold text-gray-900">Ready to clean up your data?</h3>
      <p class="mt-2 text-gray-700">See how RingsTrue can be implemented in your environment.</p>
      <a href="/contact" class="inline-block mt-4 bg-blue-600 text-white px-6 py-2 rounded-md hover:bg-blue-700 transition">
        Get a Demo
      </a>
    </div>
  </main>
</Layout>